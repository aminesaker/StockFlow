{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "functions": {
    "app/api/webhooks/stripe/route.ts": { "maxDuration": 30 },
    "app/api/invoices/[id]/pdf/route.ts": { "maxDuration": 30 },
    "app/api/cron/daily/route.ts": { "maxDuration": 60 },
    "app/api/cron/weekly/route.ts": { "maxDuration": 60 }
  },
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 7 * * 1"
    }
  ]
}
